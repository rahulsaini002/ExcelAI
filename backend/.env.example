# Copy this file to .env and fill in your real key.
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Model used for instruction -> operation-plan parsing.
# Parsing is an easy task, so a fast low-cost tier is used by default.
SUMIO_MODEL=gemini-2.5-flash

# Comma-separated list of origins allowed to call this API.
# In dev the Next.js app runs on http://localhost:3000
SUMIO_CORS_ORIGINS=http://localhost:3000
